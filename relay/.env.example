# Shared secret the Pi sends in its identify message.
# Generate with: openssl rand -hex 32
KILN_RELAY_TOKEN=replace-me-with-openssl-rand-hex-32

# Hostname the relay is reached at — used by the Traefik labels in
# docker-compose.yml. Set to whatever DNS name your reverse proxy is
# routing to this container.
KILN_HOST=kiln.example.com

# Path to your Apache htpasswd file (created e.g. with `htpasswd -c`).
# Bind-mounted into the relay read-only.
KILN_HTPASSWD_FILE=/etc/pikiln/htpasswd

# Optional: override the path to the pikiln directory (whose web/ folder is
# bind-mounted into the relay so the UI is served from a single source of truth).
# Defaults to ../pikiln relative to this compose file.
# KILN_PIKILN_DIR=../pikiln
